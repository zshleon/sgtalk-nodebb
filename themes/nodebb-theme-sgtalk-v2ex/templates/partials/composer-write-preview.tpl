<div class="write-preview-container sg-composer-body">
	<div class="write-container sg-composer-write position-relative">
		<div component="composer/post-queue/alert" class="alert alert-info fade pe-none position-absolute top-0 start-0 alert-dismissible">[[modules:composer.post-queue-alert]]<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
		<div class="draft-icon position-absolute end-0 top-0 mx-2 my-1 hidden-md hidden-lg"></div>
			<textarea class="write shadow-none form-control" placeholder="写下你想讨论的内容" data-sgtalk-i18n-placeholder="compose.bodyPlaceholder">{body}</textarea>
				<div class="sg-composer-gutter-upload" role="button" tabindex="0" data-sgtalk-i18n="quickreply.uploadHint" data-sgtalk-i18n-aria-label="quickreply.uploadHint" aria-label="选择、粘贴、拖放上传图片。">
					选择、粘贴、拖放上传图片。
				</div>
	</div>
	<div class="preview-container sg-composer-preview d-none">
		<div class="preview w-100 overflow-auto"></div>
	</div>
</div>
